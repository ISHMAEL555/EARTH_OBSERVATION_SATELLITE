"""
run_all_scenarios.py

Scenario runners for Tasks (a) to (d)
"""

import numpy as np
from simulation.simulator import ADCSSimulator
from simulation.post_process import generate_all_plots
from config import SIM_TIME_SLEW, SIM_TIME_NADIR


def nadir_target(t):
    """Nadir pointing target (identity quaternion)"""
    return np.array([1.0, 0.0, 0.0, 0.0])


def slew_target(t):
    """Simple 60° slew about non-principal axis"""
    if t < 100:
        return np.array([1.0, 0.0, 0.0, 0.0])
    else:
        # 60° rotation about [1,1,1] axis
        axis = np.array([1,1,1]) / np.sqrt(3)
        angle = np.deg2rad(60)
        q = np.array([np.cos(angle/2), 
                     axis[0]*np.sin(angle/2),
                     axis[1]*np.sin(angle/2),
                     axis[2]*np.sin(angle/2)])
        return q


def run_scenario_a(robust=False):
    """(a) Rest-to-rest slew ≥60° driving momentum >80% envelope"""
    print("\nRunning Scenario (a): Agile Slew...")
    sim = ADCSSimulator()
    results = sim.run_scenario(slew_target, SIM_TIME_SLEW, enable_dumping=False)
    generate_all_plots(results, "Scenario_A_Agile_Slew")
    return results


def run_scenario_b():
    """(b) Tracking maneuver forcing near-singularity"""
    print("\nRunning Scenario (b): Near-Singularity Tracking...")
    sim = ADCSSimulator()
    # For now use aggressive slew - can be enhanced with oscillating command
    results = sim.run_scenario(slew_target, SIM_TIME_SLEW * 0.8, enable_dumping=False)
    generate_all_plots(results, "Scenario_B_Singularity")
    return results


def run_scenario_c():
    """(c) 5-orbit nadir pointing with dumping"""
    print("\nRunning Scenario (c): 5-Orbit Nadir + Dumping...")
    sim = ADCSSimulator()
    results = sim.run_scenario(nadir_target, SIM_TIME_NADIR, enable_dumping=True)
    generate_all_plots(results, "Scenario_C_5Orbit_Nadir")
    return results


def run_scenario_d():
    """(d) Robustness check"""
    print("\nRunning Scenario (d): Robustness Analysis...")
    # Simple implementation: run nominal + print note
    results = run_scenario_a()
    print("Robustness (±10% inertia, ±5° misalignment) - Results would be generated here.")
    return results


def run_all(robust=False):
    """Run complete campaign"""
    run_scenario_a(robust=robust)
    run_scenario_b()
    run_scenario_c()
    run_scenario_d()
    print("\nAll scenarios completed.")